# Wallet (reuse from polymarket-arb-bot)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
SIGNATURE_TYPE=1

# Copy strategy
COPY_AMOUNT_USD=5
DAILY_LOSS_LIMIT=50
# G3: max simultaneous OPEN positions (0 disables)
MAX_OPEN_POSITIONS=20

# Ranker
RANK_WINDOW_DAYS=90
RANK_WEIGHTS=0.3,0.3,0.4
RANK_CANDIDATE_POOL_SIZE=50
RANK_MAX_ACTIVITY_PER_USER=3000
MIN_RESOLVED_MARKETS=20
MIN_LIFETIME_VOLUME_USD=1000
MIN_LAST_TRADE_DAYS=14

# Watcher
POLL_INTERVAL_SEC=30

# Storage
DB_PATH=data/bot.sqlite
